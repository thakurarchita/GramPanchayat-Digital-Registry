<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@drawable/splash_background_orange"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SplashActivity">


        <View
            android:id="@+id/circle1"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_centerInParent="true"
            android:background="@drawable/circle_background_orange" />

        <View
            android:id="@+id/circle2"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_centerInParent="true"
            android:background="@drawable/circle_background_light" />

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center"
            android:animateLayoutChanges="true">

            <!-- Logo Card with Shadow -->
            <androidx.cardview.widget.CardView
                android:id="@+id/logoCard"
                android:layout_width="140dp"
                android:layout_height="140dp"
                app:cardCornerRadius="70dp"
                app:cardElevation="20dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/ivLogo"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_gram_logo"
                    android:contentDescription="@string/app_name" />

            </androidx.cardview.widget.CardView>

            <!-- App Name with Gradient Text -->
            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GRAM PANCHAYAT"
                android:textColor="#FFFFFF"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:shadowColor="#000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4" />

            <!-- Tagline -->
            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Digital Household Registry"
                android:textColor="#FFF3E0"
                android:textSize="16sp"
                android:letterSpacing="0.05" />

            <!-- Admin Badge -->
            <TextView
                android:id="@+id/tvAdminBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="ADMIN PANEL"
                android:textColor="#FFE0B2"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="#80FF9800"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:letterSpacing="0.1" />

            <!-- Divider -->
            <View
                android:layout_width="60dp"
                android:layout_height="2dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="20dp"
                android:background="#FFFFFF" />

            <!-- Loading Container -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">

                <!-- Loading Text -->
                <TextView
                    android:id="@+id/tvLoading"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loading..."
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <!-- Custom Progress Bar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="12dp"
                    android:indeterminateDrawable="@drawable/progress_orange"
                    android:visibility="visible" />

            </LinearLayout>

        </LinearLayout>

        <!-- Bottom Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="30dp"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Powered By -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Powered by e-Governance"
                android:textColor="#FFE0B2"
                android:textSize="12sp" />

            <!-- Version -->
            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Version 1.0.0"
                android:textColor="#FFD180"
                android:textSize="11sp" />

        </LinearLayout>

    </RelativeLayout>