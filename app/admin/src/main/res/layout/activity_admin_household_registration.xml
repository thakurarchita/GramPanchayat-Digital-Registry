<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFF3E0"
    tools:context=".Admin_HouseholdRegistration">

    <!-- Top App Bar with Back Button -->
    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#FF9800"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/admin_login"
                android:background="?selectableItemBackgroundBorderless"
                app:tint="#FFFFFF"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Household Registration"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Household Details Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="🏠 HOUSEHOLD DETAILS"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"
                        android:layout_marginBottom="16dp"/>

                    <!-- Household Profile Photo Upload -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Household Profile Photo"
                        android:textSize="14sp"
                        android:textColor="#000000"
                        android:layout_marginTop="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:id="@+id/ivHouseholdImage"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_placeholder"
                            android:scaleType="centerCrop"
                            android:background="@drawable/edit_text_orange_border"/>

                        <Button
                            android:id="@+id/btnUploadHouseholdImage"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload Photo"
                            android:layout_gravity="center_vertical"
                            android:layout_marginStart="12dp"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Household ID (Auto-generated) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Household ID"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <TextView
                        android:id="@+id/tvHouseholdId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Will be generated by system"
                        android:textSize="14sp"
                        android:textColor="#000000"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="#F5F5F5"/>

                    <!-- Head of Family Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Head of Family Name *"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etHeadName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter head of family name"
                        android:textColorHint="#666666"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>

                    <!-- Aadhaar Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aadhaar Number *"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etAadhaar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter 12 digit Aadhaar number"
                        android:textColorHint="#666666"
                        android:inputType="number"
                        android:maxLength="12"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>

                    <!-- Address -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Address *"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter complete address"
                        android:textColorHint="#666666"
                        android:inputType="textMultiLine"
                        android:lines="3"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>

                    <!-- Mobile Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mobile Number *"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etMobile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter 10 digit mobile number"
                        android:textColorHint="#666666"
                        android:inputType="phone"
                        android:maxLength="10"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>

                    <!-- Email Address (NEW) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email Address*"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter email address"
                        android:textColorHint="#666666"
                        android:inputType="textEmailAddress"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>

                    <!-- Caste Category -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Caste Category *"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <Spinner
                        android:id="@+id/spinnerCaste"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"
                        android:theme="@style/SpinnerTheme"/>

                    <!-- Income -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Annual Income (₹) *"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etIncome"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter annual income"
                        android:textColorHint="#666666"
                        android:inputType="number"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>

                    <!-- Occupation -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Occupation"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etOccupation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter occupation"
                        android:textColorHint="#666666"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>

                    <!-- Housing Type -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Housing Type *"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <RadioGroup
                        android:id="@+id/rgHousingType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp">

                        <RadioButton
                            android:id="@+id/rbKaccha"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Kaccha"/>

                        <RadioButton
                            android:id="@+id/rbPucca"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Pucca"
                            android:checked="true"/>

                        <RadioButton
                            android:id="@+id/rbSemiPucca"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Semi-Pucca"/>
                    </RadioGroup>

                    <!-- Electricity Connection -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Electricity Connection"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <RadioGroup
                        android:id="@+id/rgElectricity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp">

                        <RadioButton
                            android:id="@+id/rbElectricityYes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Yes"
                            android:checked="true"/>

                        <RadioButton
                            android:id="@+id/rbElectricityNo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No"/>
                    </RadioGroup>

                    <!-- Toilet Availability -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toilet Availability"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <RadioGroup
                        android:id="@+id/rgToilet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp">

                        <RadioButton
                            android:id="@+id/rbToiletYes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Yes"
                            android:checked="true"/>

                        <RadioButton
                            android:id="@+id/rbToiletNo"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="No"/>
                    </RadioGroup>

                    <!-- Bank Account Details -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bank Name"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etBankName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter bank name"
                        android:textColorHint="#666666"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>

                    <!-- Account Number -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Account Number"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etAccountNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter account number"
                        android:textColorHint="#666666"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>

                    <!-- IFSC Code -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IFSC Code"
                        android:textSize="14sp"
                        android:textColor="#000000"/>

                    <EditText
                        android:id="@+id/etIfscCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Enter IFSC code"
                        android:textColorHint="#666666"
                        android:padding="12dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="12dp"
                        android:background="@drawable/edit_text_orange_border"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Family Members Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                android:backgroundTint="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="👨‍👩‍👧 FAMILY MEMBERS"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#FF9800"/>

                        <Button
                            android:id="@+id/btnAddMember"
                            android:layout_width="wrap_content"
                            android:layout_height="36dp"
                            android:text="+ Add"
                            android:textSize="12sp"
                            android:backgroundTint="#FF9800"
                            android:textColor="#FFFFFF"/>
                    </LinearLayout>

                    <!-- Dynamic Member List will be added here -->
                    <LinearLayout
                        android:id="@+id/layoutMembersContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Members will be added dynamically here -->

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="+ Click 'Add' to add more family members"
                        android:textSize="12sp"
                        android:textColor="#000000"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Register Household"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#FF9800"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>