<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:background="#E3F2FD"
    android:layout_height="match_parent"
    tools:context=".SubmitRequestActivity">


        <!-- Top App Bar -->
        <androidx.appcompat.widget.Toolbar
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#2196F3"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="?selectableItemBackgroundBorderless"
                    app:tint="#FFFFFF"
                    android:contentDescription="Back" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Submit Request"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center" />
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Request Type"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2196F3" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose the type of request you want to submit"
                android:textSize="14sp"
                android:textColor="#757575"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Request Options -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Birth Addition Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBirthRequest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:onClick="openBirthRequest"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <!-- Icon Container -->
                        <LinearLayout
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:gravity="center"
                            android:background="#E8F5E9"
                            android:layout_marginEnd="16dp"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:contentDescription="Birth Icon"
                                android:scaleType="centerInside"
                                android:src="@drawable/birth_logo" />
                        </LinearLayout>

                        <!-- Text -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Birth Addition"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add a new family member"
                                android:textSize="14sp"
                                android:textColor="#757575"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="For newborn babies"
                                android:textSize="12sp"
                                android:textColor="#4CAF50"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Arrow -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textSize="24sp"
                            android:textColor="#4CAF50"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Death Request Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardDeathRequest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:onClick="openDeathRequest"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <!-- Icon Container -->
                        <LinearLayout
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:gravity="center"
                            android:background="#FFEBEE"
                            android:layout_marginEnd="16dp"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="70dp"
                                android:layout_height="60dp"
                                android:contentDescription="Death Icon"
                                android:scaleType="centerInside"
                                android:src="@drawable/death_logo" />
                        </LinearLayout>

                        <!-- Text -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Death Request"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Report a death in family"
                                android:textSize="14sp"
                                android:textColor="#757575"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Member will be marked as Deceased"
                                android:textSize="12sp"
                                android:textColor="#F44336"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Arrow -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textSize="24sp"
                            android:textColor="#F44336"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Correction Request Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardCorrectionRequest"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:onClick="openCorrectionRequest"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?android:attr/selectableItemBackground"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="20dp">

                        <!-- Icon Container -->
                        <LinearLayout
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:gravity="center"
                            android:background="#FFF3E0"
                            android:layout_marginEnd="16dp"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="70dp"
                                android:layout_height="70dp"
                                android:contentDescription="Correction Icon"
                                android:scaleType="centerInside"
                                android:src="@drawable/correction_logo" />
                        </LinearLayout>

                        <!-- Text -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Correction Request"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#333333" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Update incorrect information"
                                android:textSize="14sp"
                                android:textColor="#757575"
                                android:layout_marginTop="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Name, DOB, Address, etc."
                                android:textSize="12sp"
                                android:textColor="#FF9800"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Arrow -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textSize="24sp"
                            android:textColor="#FF9800"
                            android:layout_marginStart="8dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Info Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="ℹ️ Important Information"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#2196F3"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• All requests are submitted for admin approval"
                            android:textSize="12sp"
                            android:textColor="#757575"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• You can track request status in Request Status section"
                            android:textSize="12sp"
                            android:textColor="#757575"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Approved requests will update the records automatically"
                            android:textSize="12sp"
                            android:textColor="#757575" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
