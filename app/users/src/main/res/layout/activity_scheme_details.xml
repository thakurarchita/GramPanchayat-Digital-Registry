<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:background="#F5F7FA"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SchemeDetailsActivity">


        <!-- Top App Bar -->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#2196F3"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:background="?selectableItemBackgroundBorderless"
                    android:tint="#FFFFFF"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Scheme Details"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </LinearLayout>
        </androidx.appcompat.widget.Toolbar>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Scheme Header Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="8dp"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">

                        <!-- Scheme Icon -->
                        <View
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/circle_blue_bg"
                            android:layout_marginBottom="12dp"/>

                        <TextView
                            android:id="@+id/tvSchemeName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Scheme Name"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:textColor="#2196F3"
                            android:gravity="center"/>

                        <TextView
                            android:id="@+id/tvCategory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Household Scheme"
                            android:textSize="14sp"
                            android:textColor="#757575"
                            android:layout_marginTop="4dp"/>

                        <!-- Category Badge -->
                        <TextView
                            android:id="@+id/tvCategoryBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Household"
                            android:textSize="12sp"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:paddingLeft="16dp"
                            android:paddingRight="16dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            android:layout_marginTop="12dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Benefit Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:text="💰"
                                android:textSize="24sp"
                                android:gravity="center"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Benefit Details"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"/>

                                <TextView
                                    android:id="@+id/tvBenefitType"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Financial"
                                    android:textSize="14sp"
                                    android:textColor="#757575"
                                    android:layout_marginTop="4dp"/>

                                <TextView
                                    android:id="@+id/tvBenefitAmount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="₹ 1,20,000"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="#4CAF50"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Key Benefits -->
                        <TextView
                            android:id="@+id/tvBenefits"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="✨ Key Benefits"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#333333"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:id="@+id/tvBenefitsList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="• Financial assistance for house construction\n• Interest subsidy on loan"
                            android:textSize="13sp"
                            android:textColor="#757575"
                            android:lineSpacingExtra="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Eligibility Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:text="✅"
                                android:textSize="24sp"
                                android:gravity="center"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Eligibility Criteria"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"/>

                                <TextView
                                    android:id="@+id/tvEligibility"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="• Income: Up to ₹3,00,000 per annum\n• Caste: All categories\n• Age: No age limit"
                                    android:textSize="13sp"
                                    android:textColor="#757575"
                                    android:layout_marginTop="8dp"
                                    android:lineSpacingExtra="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Required Documents Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:text="📄"
                                android:textSize="24sp"
                                android:gravity="center"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Required Documents"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"/>

                                <TextView
                                    android:id="@+id/tvDocuments"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="• Aadhaar Card\n• Income Certificate\n• Caste Certificate\n• Bank Passbook"
                                    android:textSize="13sp"
                                    android:textColor="#757575"
                                    android:layout_marginTop="8dp"
                                    android:lineSpacingExtra="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Application Process Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:text="📝"
                                android:textSize="24sp"
                                android:gravity="center"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Application Process"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"/>

                                <TextView
                                    android:id="@+id/tvProcess"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="1. Visit official portal\n2. Register with mobile number\n3. Fill application form\n4. Upload documents\n5. Submit application"
                                    android:textSize="13sp"
                                    android:textColor="#757575"
                                    android:layout_marginTop="8dp"
                                    android:lineSpacingExtra="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Department Info Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#FFFFFF">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="8dp">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:text="🏢"
                                android:textSize="24sp"
                                android:gravity="center"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Department"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"/>

                                <TextView
                                    android:id="@+id/tvDepartment"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Ministry of Housing"
                                    android:textSize="13sp"
                                    android:textColor="#757575"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#E0E0E0"
                            android:layout_marginVertical="12dp"/>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:text="📅"
                                android:textSize="24sp"
                                android:gravity="center"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Application Period"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#333333"/>

                                <TextView
                                    android:id="@+id/tvApplicationDates"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="01 Jan 2024 - 31 Dec 2024"
                                    android:textSize="13sp"
                                    android:textColor="#757575"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- For Individual Member -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardMemberInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    android:backgroundTint="#E8F5E9"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:text="👤"
                                android:textSize="24sp"
                                android:gravity="center"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Eligible Member"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#2E7D32"/>

                                <TextView
                                    android:id="@+id/tvMemberName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="John Doe"
                                    android:textSize="13sp"
                                    android:textColor="#757575"
                                    android:layout_marginTop="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Apply Now Button -->
                <Button
                    android:id="@+id/btnApplyNow"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Apply Now"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#FF9800"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="20dp"
                    android:drawableEnd="@drawable/ic_open_in_new"/>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
